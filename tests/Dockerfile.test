# Test runner image: Python + MySQL/PostgreSQL clients.
FROM python:3.11-slim

RUN apt-get update \
 && apt-get install -y --no-install-recommends default-mysql-client postgresql-client \
 && rm -rf /var/lib/apt/lists/*

COPY tests/requirements-test.txt /tmp/requirements-test.txt

RUN pip install --no-cache-dir -r /tmp/requirements-test.txt

COPY tests/integration_test.py /tests/integration_test.py
COPY tests/integration_test_pg.py /tests/integration_test_pg.py

WORKDIR /tests

ENTRYPOINT ["python", "/tests/integration_test.py"]

# Default: connect to services named "proxy" and run without managing
# Docker / cargo lifecycle (those are handled by Compose itself).
CMD ["--no-docker", \
     "--proxy-host", "proxy", \
     "--proxy-port", "3307", \
     "--password", "proxy_test_pw", \
     "--database", "proxy_test"]
